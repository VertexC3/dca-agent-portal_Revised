{
  "name": "AITrainingFeedback",
  "type": "object",
  "properties": {
    "communication_id": {
      "type": "string",
      "description": "ID of the related communication"
    },
    "ai_response": {
      "type": "string",
      "description": "The AI-generated response"
    },
    "feedback_type": {
      "type": "string",
      "enum": [
        "positive",
        "negative",
        "correction"
      ],
      "description": "Type of feedback"
    },
    "feedback_notes": {
      "type": "string",
      "description": "Detailed feedback or corrections"
    },
    "corrected_response": {
      "type": "string",
      "description": "Corrected version of the response"
    },
    "labels": {
      "type": "string",
      "description": "Comma-separated labels for categorization"
    },
    "training_status": {
      "type": "string",
      "enum": [
        "pending",
        "reviewed",
        "applied",
        "rejected"
      ],
      "default": "pending",
      "description": "Status of the training feedback"
    },
    "knowledge_base_referenced": {
      "type": "string",
      "description": "IDs of knowledge base articles that should be referenced"
    },
    "conversation_quality": {
      "type": "number",
      "minimum": 1,
      "maximum": 5,
      "description": "Quality rating of AI conversation (1-5)"
    },
    "improvement_area": {
      "type": "string",
      "enum": [
        "accuracy",
        "tone",
        "completeness",
        "empathy",
        "policy_compliance",
        "other"
      ],
      "description": "Area needing improvement"
    },
    "reviewed_by": {
      "type": "string",
      "description": "Email of reviewer"
    },
    "reviewed_date": {
      "type": "string",
      "format": "date-time",
      "description": "When feedback was reviewed"
    }
  },
  "required": [
    "communication_id",
    "feedback_type"
  ],
  "rls": {
    "create": {},
    "read": {
      "$or": [
        {
          "user_condition": {
            "role": "admin"
          }
        },
        {
          "user_condition": {
            "role": "representative"
          }
        }
      ]
    },
    "update": {
      "user_condition": {
        "role": "admin"
      }
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}