{
  "name": "FeatureFlag",
  "type": "object",
  "properties": {
    "key": {
      "type": "string",
      "description": "Unique key for the feature (e.g. 'patient_prescriptions')"
    },
    "label": {
      "type": "string",
      "description": "Display label for the feature"
    },
    "is_enabled": {
      "type": "boolean",
      "default": true,
      "description": "Whether the feature is enabled"
    },
    "description": {
      "type": "string",
      "description": "Description of what this feature controls"
    },
    "category": {
      "type": "string",
      "default": "patient_portal",
      "description": "Category for grouping flags"
    }
  },
  "required": [
    "key",
    "label"
  ],
  "rls": {
    "create": {
      "user_condition": {
        "role": "admin"
      }
    },
    "read": {},
    "update": {
      "user_condition": {
        "role": "admin"
      }
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}